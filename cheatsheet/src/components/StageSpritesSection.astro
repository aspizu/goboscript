---
import Section from "./Section.astro"
import SectionContent from "./SectionContent.astro"
import SectionHeader from "./SectionHeader.astro"
import SectionItem from "./SectionItem.astro"
import SectionItemCode from "./SectionItemCode.astro"
import SectionItemText from "./SectionItemText.astro"
---

<Section>
    <SectionHeader>Stage & Sprites</SectionHeader>
    <SectionContent>
        <SectionItem
            ><SectionItemCode>%include path/to/file.gs</SectionItemCode>
            <SectionItemText>Include contents of file.gs in sprite</SectionItemText>
        </SectionItem>
        <SectionItem>
            <SectionItemCode>costumes "*.svg", "path.svg" as "alias";</SectionItemCode>
            <SectionItemText>define costumes</SectionItemText>
        </SectionItem>
        <SectionItem>
            <SectionItemCode>sounds "*.mp3", "path.mp3" as "alias";</SectionItemCode>
            <SectionItemText>define sounds</SectionItemText>
        </SectionItem>
        <SectionItem>
            <SectionItemCode>set_x 100;</SectionItemCode>
            <SectionItemText>Default X position (top-level statement)</SectionItemText>
        </SectionItem>
        <SectionItem>
            <SectionItemCode>set_y 100;</SectionItemCode>
            <SectionItemText>Default Y position (top-level statement)</SectionItemText>
        </SectionItem>
        <SectionItem>
            <SectionItemCode>set_size 100;</SectionItemCode>
            <SectionItemText>Default size (top-level statement)</SectionItemText>
        </SectionItem>
        <SectionItem>
            <SectionItemCode>point_in_direction 100;</SectionItemCode>
            <SectionItemText>Default direction (top-level statement)</SectionItemText>
        </SectionItem>
        <SectionItem>
            <SectionItemCode>set_volume 100;</SectionItemCode>
            <SectionItemText>Default volume (top-level statement)</SectionItemText>
        </SectionItem>
        <SectionItem>
            <SectionItemCode>hide;</SectionItemCode>
            <SectionItemText>Hidden by default (top-level statement)</SectionItemText>
        </SectionItem>
        <SectionItem>
            <SectionItemCode>set_rotation_style_left_right;</SectionItemCode>
            <SectionItemText>(top-level statement)</SectionItemText>
        </SectionItem>
        <SectionItem>
            <SectionItemCode>set_rotation_style_all_around;</SectionItemCode>
            <SectionItemText>(top-level statement)</SectionItemText>
        </SectionItem>
        <SectionItem>
            <SectionItemCode>set_rotation_style_do_not_rotate;</SectionItemCode>
            <SectionItemText>(top-level statement)</SectionItemText>
        </SectionItem>
    </SectionContent>
</Section>
